# LLM Configuration
PPT_LLM_PROVIDER=openai
PPT_LLM_MODEL=gpt-4o-mini
PPT_LLM_TEMPERATURE=0.3
# PPT_LLM_BASE_URL=                     # Optional: override default base URL

# API Keys (fill at least one matching your provider)
PPT_OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PPT_ANTHROPIC_API_KEY=
PPT_DEEPSEEK_API_KEY=
PPT_ZHIPU_API_KEY=

# Embedding Configuration
PPT_EMBEDDING_PROVIDER=openai
PPT_EMBEDDING_MODEL=text-embedding-3-small
PPT_EMBEDDING_DIMENSIONS=768
# PPT_EMBEDDING_BASE_URL=               # Optional: override default base URL

# Gateway Configuration
MAX_UPLOAD_SIZE=52428800
RATE_LIMIT_PER_MINUTE=60

# Qdrant (optional override)
# QDRANT_URL=http://localhost:6333

# Preset examples
# ---------------------------------------------------------------
# DeepSeek LLM + Zhipu Embedding (domestic stack):
#   PPT_LLM_PROVIDER=deepseek
#   PPT_DEEPSEEK_API_KEY=sk-xxx
#   PPT_EMBEDDING_PROVIDER=zhipu
#   PPT_EMBEDDING_DIMENSIONS=2048
#   PPT_ZHIPU_API_KEY=xxx.xxx
# ---------------------------------------------------------------
# Zhipu LLM + Zhipu Embedding (all Zhipu):
#   PPT_LLM_PROVIDER=zhipu
#   PPT_ZHIPU_API_KEY=xxx.xxx
#   PPT_EMBEDDING_PROVIDER=zhipu
#   PPT_EMBEDDING_DIMENSIONS=2048
